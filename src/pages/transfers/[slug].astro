---
import Layout from '../../layouts/Layout.astro';
import BookingForm from '../../components/BookingForm';
import { transfers, getTransfer } from '../../data/transfers';

export function getStaticPaths() {
  return transfers.map(t => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const transfer = getTransfer(slug!)!;

const features = (() => {
  try { return transfer.features ? JSON.parse(transfer.features as unknown as string) : []; }
  catch { return Array.isArray(transfer.features) ? transfer.features : []; }
})();

const transferSchema = {
  '@context': 'https://schema.org',
  '@type': 'TaxiService',
  name: transfer.name,
  description: transfer.description,
  provider: {
    '@type': 'TravelAgency',
    name: 'Booking Caribe',
    url: 'https://bookingcaribe.com',
  },
  areaServed: {
    '@type': 'GeoCircle',
    geoMidpoint: {
      '@type': 'GeoCoordinates',
      latitude: 21.1619,
      longitude: -86.8515,
    },
    geoRadius: '150000',
  },
  offers: {
    '@type': 'Offer',
    price: transfer.price,
    priceCurrency: 'MXN',
  },
};
---

<Layout
  title={`${transfer.name} - Traslado ${transfer.from_location} a ${transfer.to_location}`}
  description={`Traslado ${transfer.is_private ? 'privado' : 'compartido'} de ${transfer.from_location} a ${transfer.to_location}. ${transfer.vehicle_type} para ${transfer.max_passengers} pasajeros. Desde $${transfer.price.toLocaleString('es-MX')} MXN.`}
  keywords={`traslado ${transfer.from_location} ${transfer.to_location}, transfer ${transfer.from_location}, transporte ${transfer.to_location}, ${transfer.name}`}
  schema={transferSchema}
>
  <!-- Breadcrumb bar -->
  <div class="bg-base-100 border-b-2 border-neutral/10 pt-20">
    <div class="container mx-auto px-4 py-3">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm font-semibold text-neutral/45">
        <a href="/" class="hover:text-sky-600 transition-colors">Inicio</a>
        <span>›</span>
        <a href="/transfers" class="hover:text-sky-600 transition-colors">Traslados</a>
        <span>›</span>
        <span class="text-neutral truncate max-w-[200px]">{transfer.name}</span>
      </nav>
    </div>
  </div>

  <div class="bg-base-100 min-h-screen">
    <div class="container mx-auto px-4 py-10">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- ── Main Content ── -->
        <div class="lg:col-span-2 space-y-8">

          <!-- Header -->
          <div class="reveal-up">
            <div class="flex flex-wrap gap-2 mb-3">
              <div class="inline-flex items-center gap-2 bg-sky-500 border-2 border-neutral shadow-pop-sm rounded-full px-3 py-0.5 text-white text-xs font-black uppercase tracking-widest">
                🚐 Traslado
              </div>
              <span class={`inline-flex items-center text-xs font-black px-3 py-0.5 rounded-full border-2 border-neutral shadow-pop-sm ${transfer.is_private ? 'bg-sky-500 text-white' : 'bg-accent text-neutral'}`}>
                {transfer.is_private ? 'Servicio Privado' : 'Servicio Compartido'}
              </span>
              {transfer.featured && (
                <span class="inline-flex items-center bg-secondary text-white text-xs font-black px-3 py-0.5 rounded-full border-2 border-neutral shadow-pop-sm">
                  ✦ Destacado
                </span>
              )}
              <span class="inline-flex items-center text-xs font-bold px-3 py-0.5 rounded-full border-2 border-neutral/30 text-neutral capitalize">
                {transfer.vehicle_type}
              </span>
            </div>
            <h1 class="text-3xl md:text-5xl font-black text-neutral leading-none tracking-tight">{transfer.name}</h1>
          </div>

          <!-- Route Card -->
          <div class="reveal-up delay-100 bg-white border-2 border-neutral shadow-pop rounded-2xl p-6">
            <h2 class="text-xl font-black text-neutral mb-6 flex items-center gap-2">
              <span class="w-8 h-8 bg-sky-500 rounded-lg border-2 border-neutral shadow-pop-sm flex items-center justify-center text-white text-sm">🗺️</span>
              Ruta del Traslado
            </h2>
            <div class="flex items-stretch gap-4">
              <div class="flex flex-col items-center">
                <div class="w-10 h-10 rounded-full bg-green-500 border-2 border-neutral shadow-pop-sm flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div class="flex-1 w-0.5 bg-neutral/20 my-2"></div>
                <div class="w-10 h-10 rounded-full bg-red-500 border-2 border-neutral shadow-pop-sm flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  </svg>
                </div>
              </div>
              <div class="flex-1 space-y-4">
                <div class="bg-slate-50 border-2 border-neutral/15 rounded-xl p-3">
                  <p class="text-xs text-neutral/45 uppercase tracking-widest font-black mb-0.5">Punto de Salida</p>
                  <p class="text-xl font-black text-neutral">{transfer.from_location}</p>
                </div>
                <div class="bg-slate-50 border-2 border-neutral/15 rounded-xl p-3">
                  <p class="text-xs text-neutral/45 uppercase tracking-widest font-black mb-0.5">Punto de Llegada</p>
                  <p class="text-xl font-black text-neutral">{transfer.to_location}</p>
                </div>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4 mt-6 pt-5 border-t-2 border-neutral/10">
              <div class="text-center bg-slate-50 border-2 border-neutral/10 rounded-xl p-3">
                <p class="text-xs text-neutral/45 uppercase tracking-widest font-black">Tipo de servicio</p>
                <p class="font-black text-neutral mt-1">{transfer.type === 'one-way' ? '→ Solo Ida' : '⇄ Ida y Vuelta'}</p>
              </div>
              <div class="text-center bg-slate-50 border-2 border-neutral/10 rounded-xl p-3">
                <p class="text-xs text-neutral/45 uppercase tracking-widest font-black">Capacidad</p>
                <p class="font-black text-neutral mt-1">{transfer.max_passengers} Pasajeros</p>
              </div>
            </div>
          </div>

          <!-- Description -->
          {transfer.description && (
            <div class="reveal-up delay-100 bg-white border-2 border-neutral shadow-pop rounded-2xl p-6">
              <h2 class="text-2xl font-black text-neutral mb-4 flex items-center gap-2">
                <span class="w-8 h-8 bg-sky-500 rounded-lg border-2 border-neutral shadow-pop-sm flex items-center justify-center text-white text-sm">📋</span>
                Descripción del servicio
              </h2>
              <p class="text-neutral/65 leading-relaxed">{transfer.description}</p>
            </div>
          )}

          <!-- Vehicle info -->
          <div class="reveal-up delay-200 bg-white border-2 border-neutral shadow-pop rounded-2xl p-6">
            <h2 class="text-2xl font-black text-neutral mb-5 flex items-center gap-2">
              <span class="w-8 h-8 bg-accent rounded-lg border-2 border-neutral shadow-pop-sm flex items-center justify-center text-neutral text-sm">🚐</span>
              Información del vehículo
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="flex items-center gap-4 p-4 bg-slate-50 border-2 border-neutral/10 rounded-xl">
                <div class="w-12 h-12 rounded-xl bg-sky-50 border-2 border-sky-200 flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-neutral/45 font-black uppercase tracking-wider">Tipo de vehículo</p>
                  <p class="text-lg font-black text-neutral capitalize">{transfer.vehicle_type}</p>
                </div>
              </div>
              <div class="flex items-center gap-4 p-4 bg-slate-50 border-2 border-neutral/10 rounded-xl">
                <div class="w-12 h-12 rounded-xl bg-sky-50 border-2 border-sky-200 flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-neutral/45 font-black uppercase tracking-wider">Capacidad máxima</p>
                  <p class="text-lg font-black text-neutral">{transfer.max_passengers} Pasajeros</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Features -->
          {features.length > 0 && (
            <div class="reveal-up delay-200 bg-white border-2 border-neutral shadow-pop rounded-2xl p-6">
              <h2 class="text-2xl font-black text-neutral mb-5 flex items-center gap-2">
                <span class="w-8 h-8 bg-sky-500 rounded-lg border-2 border-neutral shadow-pop-sm flex items-center justify-center text-white text-sm">✓</span>
                Características incluidas
              </h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {features.map((feature: string) => (
                  <div class="flex items-center gap-2.5 p-3 bg-slate-50 border-2 border-neutral/10 rounded-xl text-sm hover:border-sky-500/30 transition-colors">
                    <div class="w-5 h-5 rounded-full bg-sky-100 border-2 border-sky-300 flex items-center justify-center shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <span class="font-semibold text-neutral">{feature}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Info alerts -->
          <div class="reveal-up delay-300 space-y-3">
            <div class="bg-white border-2 border-sky-200 rounded-2xl p-4">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-sky-50 border-2 border-sky-200 rounded-xl flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="font-black text-sm text-neutral">Información de llegada</p>
                  <p class="text-sm text-neutral/60 mt-0.5 leading-relaxed">El conductor te esperará con un letrero con tu nombre en el área de llegadas.</p>
                </div>
              </div>
            </div>
            <div class="bg-white border-2 border-green-200 rounded-2xl p-4">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-green-100 border-2 border-green-300 rounded-xl flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                </div>
                <div>
                  <p class="font-black text-sm text-neutral">Cancelación Gratuita</p>
                  <p class="text-sm text-neutral/60 mt-0.5 leading-relaxed">Cancela hasta 24 horas antes sin ningún cargo.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ── Sidebar ── -->
        <div class="lg:col-span-1">
          <div class="sticky top-24 space-y-4">

            <!-- Booking card -->
            <div class="bg-white border-2 border-neutral shadow-pop rounded-2xl p-6 reveal-right">
              <div class="mb-5 text-center">
                <p class="text-xs text-neutral/45 uppercase tracking-widest font-black mb-1">
                  {transfer.type === 'one-way' ? 'Solo ida' : 'Ida y vuelta'}
                </p>
                <p class="text-4xl font-black price-gradient">
                  ${transfer.price.toLocaleString('es-MX')}
                  <span class="text-sm font-normal text-neutral/45 ml-1">MXN</span>
                </p>
              </div>

              <div class="border-t-2 border-neutral/10 my-4"></div>

              <BookingForm
                client:load
                itemType="transfer"
                itemId={transfer.id}
                itemName={transfer.name}
                itemPrice={transfer.price}
                itemSlug={transfer.slug}
              />

              <div class="border-t-2 border-neutral/10 my-4"></div>

              <!-- Trust points -->
              <ul class="space-y-2 mb-4">
                {['Servicio 24/7', 'Conductores certificados', 'Vehículos nuevos', 'Seguimiento en tiempo real'].map(item => (
                  <li class="flex items-center gap-2 text-xs font-semibold text-neutral/60">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>

              <a
                href="tel:+529981234567"
                class="w-full inline-flex items-center justify-center gap-2 h-10 bg-white border-2 border-neutral shadow-pop-sm rounded-full text-sm font-black text-neutral
                       hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-pop transition-all duration-150"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                ¿Dudas? Llámanos
              </a>
            </div>

            <!-- Trust card -->
            <div class="bg-white border-2 border-neutral/15 rounded-2xl p-4 space-y-3 reveal-right delay-100">
              {[
                { icon: '🛡️', title: 'Seguro incluido', desc: 'Cobertura total del trayecto' },
                { icon: '⏰', title: 'Puntualidad garantizada', desc: 'O te devolvemos el dinero' },
                { icon: '💳', title: 'Pago seguro', desc: 'Transacciones cifradas SSL' },
              ].map(({ icon, title, desc }) => (
                <div class="flex items-center gap-3 text-sm">
                  <span class="text-xl w-7 text-center">{icon}</span>
                  <div>
                    <p class="font-black text-neutral leading-none">{title}</p>
                    <p class="text-xs text-neutral/45 mt-0.5">{desc}</p>
                  </div>
                </div>
              ))}
            </div>

          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Bottom CTA -->
  <section class="bg-slate-50 border-t-2 border-neutral/10 py-14">
    <div class="container mx-auto px-4 text-center">
      <p class="text-xs font-black uppercase tracking-widest text-neutral/40 mb-2">¿Necesitas otra ruta?</p>
      <h2 class="text-3xl font-black text-neutral mb-2">Más opciones de traslado</h2>
      <p class="text-neutral/55 mb-6">Explora todas las rutas disponibles en el Caribe Mexicano</p>
      <a
        href="/transfers"
        class="inline-flex items-center gap-2 bg-sky-500 text-white font-black px-8 py-3 rounded-full border-2 border-neutral shadow-pop hover:-translate-x-px hover:-translate-y-px hover:shadow-pop-lg transition-all"
      >
        Ver todos los traslados →
      </a>
    </div>
  </section>
</Layout>
