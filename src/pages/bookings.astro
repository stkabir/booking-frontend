---
import Layout from '../layouts/Layout.astro';

// Pre-fill booking number from query param (set after checkout confirmation)
const urlBookingNumber = Astro.url.searchParams.get('number') || '';
---

<Layout
  title="Consultar Reserva - Booking Caribe"
  description="Consulta el estado de tus reservas de tours, hoteles y traslados en el Caribe Mexicano."
  noindex={true}
>
  <div class="container mx-auto px-4 py-16 max-w-2xl">
    <div class="text-center mb-10">
      <h1 class="text-3xl font-black text-neutral mb-3">Consultar mi Reserva</h1>
      <p class="text-neutral/60">
        Ingresa tu número de reserva para ver el estado de tu reserva.
      </p>
    </div>

    <!-- Main Card -->
    <div class="bg-white border-2 border-neutral shadow-pop rounded-2xl">
      <div class="p-8">
        <form id="lookup-form" class="space-y-5">
          <div>
            <label for="booking-number" class="block text-xs font-black uppercase tracking-wider text-neutral/50 mb-1.5">
              Número de Reserva *
            </label>
            <input
              type="text"
              id="booking-number"
              value={urlBookingNumber}
              placeholder="Ej: BC-2026-0001"
              class="pg-input font-mono w-full"
              required
            />
          </div>

          <button
            type="submit"
            id="lookup-btn"
            class="w-full h-11 flex items-center justify-center gap-2 bg-violet-500 text-white font-black text-base rounded-full border-2 border-neutral shadow-[3px_3px_0px_0px_#1E293B] hover:translate-x-px hover:translate-y-px hover:shadow-[2px_2px_0px_0px_#1E293B] active:translate-x-[3px] active:translate-y-[3px] active:shadow-none transition-all disabled:opacity-60 disabled:cursor-not-allowed disabled:translate-x-0 disabled:translate-y-0"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            Buscar reserva
          </button>
        </form>

        <!-- Error State -->
        <div id="booking-error" class="hidden mt-6">
          <div class="border-t-2 border-neutral/10 mb-5"></div>
          <div class="flex items-start gap-3 bg-red-50 border-2 border-red-300 rounded-2xl px-4 py-3.5">
            <div class="w-8 h-8 rounded-lg bg-red-500 border-2 border-red-700 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </div>
            <span id="booking-error-msg" class="text-sm font-medium text-red-700 mt-1">Reserva no encontrada.</span>
          </div>
        </div>

        <!-- Result Card -->
        <div id="booking-result" class="hidden mt-6">
          <div class="border-t-2 border-neutral/10 mb-5"></div>

          <!-- Booking Number -->
          <div class="text-center mb-5">
            <p class="text-xs text-neutral/50 uppercase tracking-widest mb-1 font-bold">Número de Reserva</p>
            <p id="res-number" class="text-2xl font-black font-mono tracking-wider price-gradient"></p>
          </div>

          <!-- Status + Item -->
          <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
            <div>
              <p class="text-xs text-neutral/50 font-bold mb-0.5">Servicio</p>
              <p id="res-item" class="font-black text-lg text-neutral"></p>
            </div>
            <div class="flex gap-2 flex-wrap">
              <span id="res-status"></span>
              <span id="res-payment-status"></span>
            </div>
          </div>

          <!-- Details Grid -->
          <div class="grid grid-cols-2 gap-4 text-sm mb-5">
            <div>
              <p class="text-neutral/50 text-xs font-bold uppercase tracking-wide">Cliente</p>
              <p id="res-name" class="font-semibold text-neutral mt-0.5"></p>
            </div>
            <div>
              <p class="text-neutral/50 text-xs font-bold uppercase tracking-wide">Email</p>
              <p id="res-email" class="font-semibold text-neutral mt-0.5"></p>
            </div>
            <div>
              <p class="text-neutral/50 text-xs font-bold uppercase tracking-wide">Teléfono</p>
              <p id="res-phone" class="font-semibold text-neutral mt-0.5"></p>
            </div>
            <div>
              <p class="text-neutral/50 text-xs font-bold uppercase tracking-wide">Fecha</p>
              <p id="res-date" class="font-semibold text-neutral mt-0.5"></p>
            </div>
            <div>
              <p class="text-neutral/50 text-xs font-bold uppercase tracking-wide">Pasajeros / Huéspedes</p>
              <p id="res-guests" class="font-semibold text-neutral mt-0.5"></p>
            </div>
            <div>
              <p class="text-neutral/50 text-xs font-bold uppercase tracking-wide">Método de Pago</p>
              <p id="res-payment" class="font-semibold text-neutral mt-0.5 capitalize"></p>
            </div>
          </div>

          <!-- Total -->
          <div class="bg-slate-50 border-2 border-slate-100 rounded-2xl p-4 flex justify-between items-center">
            <span class="text-sm text-neutral/60 font-medium">Total de la reserva</span>
            <span id="res-total" class="text-2xl font-black price-gradient"></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Help Links -->
    <div class="mt-8 text-center space-y-3">
      <p class="text-neutral/60 text-sm">¿No encuentras tu reserva?</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="https://wa.me/529981234567"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 h-9 px-4 text-sm font-bold rounded-full bg-green-500 text-white border-2 border-neutral shadow-pop-sm hover:translate-x-px hover:translate-y-px hover:shadow-none transition-all"
        >
          Chat WhatsApp
        </a>
        <a
          href="/contact"
          class="inline-flex items-center h-9 px-4 text-sm font-semibold rounded-full border-2 border-neutral text-neutral shadow-pop-sm hover:translate-x-px hover:translate-y-px hover:shadow-none transition-all"
        >
          Formulario de contacto
        </a>
        <a
          href="tel:+529981234567"
          class="inline-flex items-center h-9 px-4 text-sm font-semibold rounded-full border-2 border-transparent text-neutral/60 hover:text-neutral hover:border-neutral/20 transition-all"
        >
          Llamar
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api';

  const form = document.getElementById('lookup-form') as HTMLFormElement;
  const btn = document.getElementById('lookup-btn') as HTMLButtonElement;
  const errorBox = document.getElementById('booking-error') as HTMLDivElement;
  const errorMsg = document.getElementById('booking-error-msg') as HTMLSpanElement;
  const resultBox = document.getElementById('booking-result') as HTMLDivElement;

  function hide(...els: HTMLElement[]) { els.forEach(el => el.classList.add('hidden')); }
  function show(...els: HTMLElement[]) { els.forEach(el => el.classList.remove('hidden')); }
  function setText(id: string, text: string) { const el = document.getElementById(id); if (el) el.textContent = text; }

  function formatDate(dateString: string) {
    return new Date(dateString).toLocaleDateString('es-MX', {
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
    });
  }

  function statusLabel(status: string) {
    const map: Record<string, string> = {
      pending: 'Pendiente', confirmed: 'Confirmada', cancelled: 'Cancelada', completed: 'Completada',
    };
    return map[status] ?? status;
  }

  function paymentStatusLabel(status: string) {
    const map: Record<string, string> = {
      pending: 'Pago pendiente', paid: 'Pagado', refunded: 'Reembolsado', failed: 'Fallido',
    };
    return map[status] ?? status;
  }

  const statusPillCls: Record<string, string> = {
    confirmed: 'inline-flex items-center text-xs font-black px-3 py-1 rounded-full border-2 border-green-600 bg-green-100 text-green-700',
    cancelled:  'inline-flex items-center text-xs font-black px-3 py-1 rounded-full border-2 border-red-500 bg-red-100 text-red-700',
    completed:  'inline-flex items-center text-xs font-black px-3 py-1 rounded-full border-2 border-sky-500 bg-sky-100 text-sky-700',
    default:    'inline-flex items-center text-xs font-black px-3 py-1 rounded-full border-2 border-amber-400 bg-amber-100 text-amber-700',
  };

  const paymentPillCls: Record<string, string> = {
    paid:    'inline-flex items-center text-xs font-black px-3 py-1 rounded-full border-2 border-green-500 bg-green-50 text-green-700',
    default: 'inline-flex items-center text-xs font-black px-3 py-1 rounded-full border-2 border-neutral/25 bg-transparent text-neutral/55',
  };

  const searchIconSvg = '<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>';
  const spinnerSvg = '<svg class="h-4 w-4 animate-spin shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>';

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    hide(errorBox, resultBox);

    const numberInput = document.getElementById('booking-number') as HTMLInputElement;
    const bookingNumber = numberInput.value.trim();
    if (!bookingNumber) return;

    btn.disabled = true;
    btn.innerHTML = `${spinnerSvg} Buscando...`;

    try {
      const res = await fetch(`${API_URL}/bookings/${encodeURIComponent(bookingNumber)}`, {
        headers: { Accept: 'application/json' },
      });

      if (!res.ok) {
        errorMsg.textContent = res.status === 404
          ? 'No encontramos una reserva con ese número. Verifica e intenta de nuevo.'
          : 'Error al consultar la reserva. Por favor intenta más tarde.';
        show(errorBox);
        return;
      }

      const json = await res.json();
      const booking = json?.data ?? json;

      // Populate fields
      setText('res-number', booking.booking_number);
      setText('res-item', booking.bookable?.name ?? `Servicio #${booking.bookable_id}`);
      setText('res-name', booking.customer_name);
      setText('res-email', booking.customer_email);
      setText('res-phone', booking.customer_phone);
      setText('res-date', formatDate(booking.start_date));
      setText('res-guests', `${booking.adults} adulto${booking.adults !== 1 ? 's' : ''}${booking.children > 0 ? ` + ${booking.children} niño${booking.children !== 1 ? 's' : ''}` : ''}`);
      setText('res-payment', booking.payment_method ?? 'No especificado');
      setText('res-total', `$${Number(booking.total).toLocaleString('es-MX')} MXN`);

      const statusEl = document.getElementById('res-status');
      const paymentStatusEl = document.getElementById('res-payment-status');
      if (statusEl) {
        statusEl.textContent = statusLabel(booking.status);
        statusEl.className = statusPillCls[booking.status] ?? statusPillCls.default;
      }
      if (paymentStatusEl) {
        paymentStatusEl.textContent = paymentStatusLabel(booking.payment_status);
        paymentStatusEl.className = paymentPillCls[booking.payment_status] ?? paymentPillCls.default;
      }

      show(resultBox);
    } catch {
      errorMsg.textContent = 'No se pudo conectar con el servidor. Por favor intenta más tarde.';
      show(errorBox);
    } finally {
      btn.disabled = false;
      btn.innerHTML = `${searchIconSvg} Buscar reserva`;
    }
  });

  // Auto-submit if booking number is pre-filled from URL param
  const prefilled = (document.getElementById('booking-number') as HTMLInputElement)?.value;
  if (prefilled) {
    form?.dispatchEvent(new Event('submit'));
  }
</script>
