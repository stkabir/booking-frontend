---
import Layout from '../../layouts/Layout.astro';
import BookingForm from '../../components/BookingForm';
import { api } from '../../lib/api';

const { slug } = Astro.params;

let hotel;
try {
  hotel = await api.getHotel(slug!);
} catch {
  return Astro.redirect('/hotels');
}

const amenities = (() => {
  try { return hotel.amenities ? JSON.parse(hotel.amenities as unknown as string) : []; }
  catch { return Array.isArray(hotel.amenities) ? hotel.amenities : []; }
})();

const hotelSchema = {
  '@context': 'https://schema.org',
  '@type': 'Hotel',
  name: hotel.name,
  description: hotel.description,
  address: {
    '@type': 'PostalAddress',
    streetAddress: hotel.address,
    addressLocality: hotel.city,
    addressRegion: hotel.state,
    addressCountry: 'MX',
  },
  starRating: { '@type': 'Rating', ratingValue: hotel.stars },
  priceRange: `$${hotel.price_per_night} MXN por noche`,
  url: `https://bookingcaribe.com/hotels/${hotel.slug}`,
};
---

<Layout
  title={`${hotel.name} - Hotel en ${hotel.city}`}
  description={`Reserva ${hotel.name} en ${hotel.city}, ${hotel.state}. ${hotel.stars} estrellas. Desde $${hotel.price_per_night.toLocaleString('es-MX')} MXN por noche. ${hotel.description?.slice(0, 120) || ''}`}
  keywords={`${hotel.name}, hotel ${hotel.city}, alojamiento ${hotel.city}, hotel ${hotel.state}, reservar ${hotel.name}`}
  schema={hotelSchema}
>
  <!-- Breadcrumb bar -->
  <div class="bg-base-100 border-b-2 border-neutral/10 pt-20">
    <div class="container mx-auto px-4 py-3">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm font-semibold text-neutral/45">
        <a href="/" class="hover:text-emerald-600 transition-colors">Inicio</a>
        <span>›</span>
        <a href="/hotels" class="hover:text-emerald-600 transition-colors">Hoteles</a>
        <span>›</span>
        <span class="text-neutral truncate max-w-[200px]">{hotel.name}</span>
      </nav>
    </div>
  </div>

  <div class="bg-base-100 min-h-screen">
    <div class="container mx-auto px-4 py-10">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- ── Main Content ── -->
        <div class="lg:col-span-2 space-y-8">

          <!-- Header -->
          <div class="reveal-up">
            <div class="flex flex-wrap items-start justify-between gap-4 mb-3">
              <div class="flex-1">
                <!-- Category chip -->
                <div class="inline-flex items-center gap-2 bg-emerald-500 border-2 border-neutral shadow-pop-sm rounded-full px-3 py-0.5 text-white text-xs font-black uppercase tracking-widest mb-3">
                  🏨 Hotel
                </div>
                <h1 class="text-3xl md:text-5xl font-black text-neutral leading-none tracking-tight">{hotel.name}</h1>
                <div class="flex items-center gap-3 mt-3">
                  <div class="flex gap-0.5">
                    {[...Array(hotel.stars)].map(() => (
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-400 fill-amber-400" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    ))}
                  </div>
                  <span class="text-sm font-bold text-neutral/50">{hotel.stars} estrellas</span>
                  {hotel.featured && (
                    <span class="inline-flex items-center bg-secondary text-white text-xs font-black px-3 py-0.5 rounded-full border-2 border-neutral shadow-pop-sm">
                      ✦ Destacado
                    </span>
                  )}
                </div>
              </div>
            </div>

            <div class="flex items-center gap-1.5 text-sm text-neutral/55 font-medium mt-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {hotel.address ? `${hotel.address}, ` : ''}{hotel.city}{hotel.state ? `, ${hotel.state}` : ''}, {hotel.country}
            </div>
          </div>

          <!-- Hero image -->
          <div class="reveal-up delay-100 h-72 md:h-96 rounded-2xl overflow-hidden relative border-2 border-neutral shadow-pop">
            <div class="absolute inset-0 bg-emerald-50"></div>
            <div class="absolute inset-0 pattern-dots-light opacity-50" aria-hidden="true"></div>
            <!-- Decorative shapes -->
            <div class="absolute top-6 right-6 w-24 h-24 rounded-full bg-emerald-200/60 border-2 border-emerald-300/40"></div>
            <div class="absolute bottom-8 left-8 w-20 h-20 rounded-full bg-emerald-300/30 border-2 border-emerald-400/25"></div>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <div class="text-8xl opacity-40">🏨</div>
              <p class="mt-3 text-sm font-bold text-emerald-700/50">Foto del hotel próximamente</p>
            </div>
            <!-- Price tag overlay -->
            <div class="absolute bottom-4 right-4 bg-white border-2 border-neutral shadow-pop-sm rounded-xl px-4 py-2">
              <p class="text-xs text-neutral/50 font-medium">Por noche desde</p>
              <p class="text-xl font-black price-gradient">${hotel.price_per_night.toLocaleString('es-MX')} <span class="text-xs font-normal text-neutral/40">MXN</span></p>
            </div>
          </div>

          <!-- Description -->
          <div class="reveal-up delay-100 bg-white border-2 border-neutral shadow-pop rounded-2xl p-6">
            <h2 class="text-2xl font-black text-neutral mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-emerald-500 rounded-lg border-2 border-neutral shadow-pop-sm flex items-center justify-center text-white text-sm">📋</span>
              Acerca del Hotel
            </h2>
            <p class="text-neutral/65 leading-relaxed">{hotel.description}</p>
          </div>

          <!-- Amenities -->
          {amenities.length > 0 && (
            <div class="reveal-up delay-200 bg-white border-2 border-neutral shadow-pop rounded-2xl p-6">
              <h2 class="text-2xl font-black text-neutral mb-5 flex items-center gap-2">
                <span class="w-8 h-8 bg-accent rounded-lg border-2 border-neutral shadow-pop-sm flex items-center justify-center text-neutral text-sm">✓</span>
                Servicios e Instalaciones
              </h2>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                {amenities.map((amenity: string) => (
                  <div class="flex items-center gap-2.5 p-3 bg-slate-50 border-2 border-neutral/10 rounded-xl text-sm hover:border-emerald-500/30 transition-colors">
                    <div class="w-5 h-5 rounded-full bg-emerald-100 border-2 border-emerald-400 flex items-center justify-center shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-emerald-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <span class="font-semibold text-neutral">{amenity}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Location -->
          {hotel.latitude && hotel.longitude && (
            <div class="reveal-up delay-200 bg-white border-2 border-neutral shadow-pop rounded-2xl p-6">
              <h2 class="text-2xl font-black text-neutral mb-4 flex items-center gap-2">
                <span class="w-8 h-8 bg-secondary rounded-lg border-2 border-neutral shadow-pop-sm flex items-center justify-center text-white text-sm">📍</span>
                Ubicación
              </h2>
              <div class="h-48 bg-slate-50 border-2 border-neutral/15 rounded-xl flex flex-col items-center justify-center text-neutral/40">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                </svg>
                <p class="text-sm font-bold">{hotel.city}{hotel.state ? `, ${hotel.state}` : ''}</p>
                <p class="text-xs mt-1 font-mono text-neutral/30">{hotel.latitude.toFixed(4)}, {hotel.longitude.toFixed(4)}</p>
              </div>
            </div>
          )}

          <!-- Reviews placeholder -->
          <div class="reveal-up delay-300 bg-white border-2 border-neutral shadow-pop rounded-2xl p-6">
            <h2 class="text-2xl font-black text-neutral mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-amber-400 rounded-lg border-2 border-neutral shadow-pop-sm flex items-center justify-center text-neutral text-sm">⭐</span>
              Reseñas de Huéspedes
            </h2>
            <div class="bg-slate-50 border-2 border-dashed border-neutral/20 rounded-xl p-8 text-center">
              <p class="text-4xl mb-3">⭐</p>
              <p class="font-black text-neutral/60">Las reseñas estarán disponibles próximamente</p>
              <p class="text-sm text-neutral/40 mt-1">¡Sé el primero en dejar una reseña!</p>
            </div>
          </div>
        </div>

        <!-- ── Sidebar ── -->
        <div class="lg:col-span-1">
          <div class="sticky top-24 space-y-4">

            <!-- Booking card -->
            <div class="bg-white border-2 border-neutral shadow-pop rounded-2xl p-6 reveal-right">
              <div class="mb-5">
                <p class="text-xs text-neutral/45 uppercase tracking-widest font-black mb-1">Precio por noche desde</p>
                <p class="text-4xl font-black price-gradient">
                  ${hotel.price_per_night.toLocaleString('es-MX')}
                  <span class="text-sm font-normal text-neutral/45 ml-1">MXN</span>
                </p>
                <p class="text-xs text-neutral/40 mt-1">+ impuestos (IVA 16%)</p>
              </div>

              <div class="border-t-2 border-neutral/10 my-4"></div>

              <BookingForm
                client:load
                itemType="hotel"
                itemId={hotel.id}
                itemName={hotel.name}
                itemPrice={hotel.price_per_night}
                itemSlug={hotel.slug}
              />

              <div class="border-t-2 border-neutral/10 my-4"></div>

              <div class="space-y-2">
                <a
                  href="tel:+529981234567"
                  class="w-full inline-flex items-center justify-center gap-2 h-10 bg-white border-2 border-neutral shadow-pop-sm rounded-full text-sm font-black text-neutral
                         hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-pop transition-all duration-150"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  Llamar ahora
                </a>
                <a href="/contact" class="w-full inline-flex items-center justify-center h-9 text-sm font-bold text-neutral/50 hover:text-neutral transition-colors">
                  ¿Tienes dudas? Contáctanos
                </a>
              </div>
            </div>

            <!-- Trust card -->
            <div class="bg-white border-2 border-neutral/15 rounded-2xl p-4 reveal-right delay-100">
              <div class="flex items-start gap-3">
                <div class="w-9 h-9 bg-green-100 border-2 border-green-300 rounded-xl flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                </div>
                <div>
                  <p class="font-black text-sm text-neutral">Cancelación Gratuita</p>
                  <p class="text-xs text-neutral/55 mt-0.5 leading-relaxed">Cancela hasta 48 horas antes del check-in sin cargos adicionales.</p>
                </div>
              </div>
            </div>

            <!-- More trust items -->
            <div class="bg-white border-2 border-neutral/15 rounded-2xl p-4 space-y-3 reveal-right delay-200">
              {[
                { icon: '💳', title: 'Pago seguro', desc: 'Transacciones cifradas SSL' },
                { icon: '✅', title: 'Confirmación inmediata', desc: 'Recibes email al instante' },
                { icon: '🏆', title: 'Mejor precio', desc: 'Garantizado o te devolvemos la diferencia' },
              ].map(({ icon, title, desc }) => (
                <div class="flex items-center gap-3 text-sm">
                  <span class="text-xl w-7 text-center">{icon}</span>
                  <div>
                    <p class="font-black text-neutral leading-none">{title}</p>
                    <p class="text-xs text-neutral/45 mt-0.5">{desc}</p>
                  </div>
                </div>
              ))}
            </div>

          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Bottom CTA -->
  <section class="bg-slate-50 border-t-2 border-neutral/10 py-14">
    <div class="container mx-auto px-4 text-center">
      <p class="text-xs font-black uppercase tracking-widest text-neutral/40 mb-2">¿No es lo que buscas?</p>
      <h2 class="text-3xl font-black text-neutral mb-2">Más hoteles en {hotel.city}</h2>
      <p class="text-neutral/55 mb-6">Explora todas las opciones de alojamiento disponibles</p>
      <a
        href="/hotels"
        class="inline-flex items-center gap-2 bg-emerald-500 text-white font-black px-8 py-3 rounded-full border-2 border-neutral shadow-pop hover:-translate-x-px hover:-translate-y-px hover:shadow-pop-lg transition-all"
      >
        Ver todos los hoteles →
      </a>
    </div>
  </section>
</Layout>
