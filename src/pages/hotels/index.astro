---
import Layout from '../../layouts/Layout.astro';
import HotelList from '../../components/HotelList';
import { api } from '../../lib/api';

const hotels = await api.getHotels().catch(() => []);
---

<Layout
  title="Hoteles en Riviera Maya y Cancún"
  description="Encuentra los mejores hoteles en Cancún, Playa del Carmen, Tulum y toda la Riviera Maya. Reserva al mejor precio con cancelación gratuita."
  keywords="hoteles cancun, hoteles riviera maya, hoteles playa del carmen, hoteles tulum, alojamiento caribe mexicano, resorts cancun, hoteles 5 estrellas cancun"
>
  <!-- ══════════════════════════════════════════
       PAGE HEADER — Playful Geometric
  ══════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-base-100" aria-label="Hoteles">
    <!-- Dot grid -->
    <div class="absolute inset-0 pattern-dots-light opacity-50" aria-hidden="true"></div>
    <!-- Decorative shapes -->
    <div class="absolute -top-12 right-0 w-72 h-72 rounded-full bg-emerald-500/20 border-2 border-emerald-600/15 translate-x-1/4" aria-hidden="true"></div>
    <div class="absolute top-20 right-28 w-14 h-14 bg-accent border-2 border-neutral rotate-12 hidden md:block" aria-hidden="true"></div>
    <div class="absolute top-36 right-12 w-9 h-9 rounded-full bg-secondary border-2 border-neutral hidden lg:block" aria-hidden="true"></div>
    <div class="absolute bottom-8 left-12 w-20 h-20 rounded-full bg-emerald-500/15 border-2 border-emerald-600/20 hidden md:block" aria-hidden="true"></div>
    <div class="absolute bottom-16 left-1/3 text-2xl hidden lg:block select-none text-secondary" aria-hidden="true">◆</div>
    <div class="absolute top-20 left-1/4 text-xl hidden lg:block select-none text-primary/40" aria-hidden="true">✦</div>

    <div class="container mx-auto px-4 pt-28 pb-14 relative z-10">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm font-semibold text-neutral/45 mb-6">
        <a href="/" class="hover:text-primary transition-colors">Inicio</a>
        <span>›</span>
        <span class="text-neutral">Hoteles</span>
      </nav>

      <!-- Category chip -->
      <div class="inline-flex items-center gap-2 bg-emerald-500 border-2 border-neutral shadow-pop-sm rounded-full px-4 py-1 text-white text-xs font-black uppercase tracking-widest mb-5">
        🏨 Alojamiento
      </div>

      <h1 class="text-5xl md:text-7xl font-black text-neutral leading-none tracking-tighter mb-5">
        Hoteles en el<br>
        <span class="text-emerald-600">Caribe Mexicano</span>
      </h1>
      <p class="text-lg text-neutral/60 max-w-xl leading-relaxed mb-8">
        Desde boutiques frente al mar hasta resorts all-inclusive. Encuentra el alojamiento perfecto para tus vacaciones.
      </p>

      <!-- Feature chips -->
      <div class="flex flex-wrap gap-2">
        {[
          { icon: '🏨', label: `${hotels.length}+ hoteles disponibles` },
          { icon: '✅', label: 'Cancelación gratuita' },
          { icon: '💳', label: 'Mejor precio garantizado' },
          { icon: '⭐', label: 'Reseñas verificadas' },
        ].map(({ icon, label }) => (
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-neutral bg-white border-2 border-neutral shadow-pop-sm rounded-full px-3 py-1.5">
            {icon} {label}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       HOTEL LIST WITH FILTERS (React)
  ══════════════════════════════════════════ -->
  <div class="bg-base-100">
    <div class="container mx-auto px-4 py-12">
      <HotelList client:load initialHotels={hotels} />
    </div>
  </div>

  <!-- ══════════════════════════════════════════
       SEO CONTENT BLOCK
  ══════════════════════════════════════════ -->
  <section class="bg-slate-50 border-t-2 border-neutral/10 py-16">
    <div class="container mx-auto px-4 max-w-3xl">
      <div class="inline-flex items-center gap-2 bg-accent border-2 border-neutral shadow-pop-sm rounded-full px-4 py-1 text-neutral text-xs font-black uppercase tracking-widest mb-4 reveal-up">
        ¿Por qué Booking Caribe?
      </div>
      <h2 class="text-3xl font-black text-neutral mb-8 reveal-up delay-100">Por qué reservar tu hotel con nosotros</h2>
      <div class="grid md:grid-cols-2 gap-6 reveal-up delay-200">
        {[
          { title: 'Selección curada', desc: 'Cada hotel ha sido revisado por nuestro equipo. Solo publicamos alojamientos con excelentes reseñas y relación calidad-precio.', color: 'bg-emerald-100', border: 'border-emerald-400' },
          { title: 'Precio más bajo garantizado', desc: 'Si encuentras el mismo hotel más barato en otro sitio, te hacemos el reembolso de la diferencia.', color: 'bg-amber-100', border: 'border-amber-400' },
          { title: 'Destinos en Riviera Maya', desc: 'Cancún, Playa del Carmen, Tulum, Cozumel, Isla Mujeres y muchos más destinos del Caribe Mexicano.', color: 'bg-pink-100', border: 'border-pink-300' },
          { title: 'Reserva en minutos', desc: 'Proceso de reserva simple y seguro. Confirmación inmediata por email con todos los detalles de tu estancia.', color: 'bg-sky-100', border: 'border-sky-300' },
        ].map(({ title, desc, color, border }) => (
          <div class={`bg-white border-2 border-neutral shadow-pop rounded-xl p-5`}>
            <div class={`w-10 h-10 ${color} border-2 ${border} rounded-lg flex items-center justify-center text-lg mb-3`}>✓</div>
            <h3 class="font-black text-neutral mb-1">{title}</h3>
            <p class="text-sm text-neutral/60 leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
