    <div class="absolute inset-0 pattern-dots-light opacity-40" aria-hidden="true"></div>
    <!-- Amber blob decoration -->
    <div class="absolute -top-16 -right-16 w-72 h-72 rounded-full bg-accent/30 border-2 border-neutral/20" aria-hidden="true"></div>
    <div class="absolute -bottom-16 -left-16 w-56 h-56 rounded-full bg-secondary/20 border-2 border-neutral/20" aria-hidden="true"></div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="text-center mb-14">
        <div class="reveal-up inline-flex items-center gap-2 bg-accent border-2 border-neutral shadow-pop-sm rounded-full px-4 py-1 text-neutral text-xs font-bold mb-4 uppercase tracking-widest">
          ¿Por qué Booking Caribe?
        </div>
        <h2 class="reveal-up delay-100 text-4xl md:text-5xl font-black text-neutral">
          La diferencia que sientes<br class="hidden md:block"/> desde el primer click
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: '🛡️', title: 'Pago 100% Seguro', desc: 'Transacciones protegidas con encriptación SSL. Tu dinero siempre está a salvo.', bg: 'bg-primary/15', border: 'border-primary' },
          { icon: '⚡', title: 'Confirmación Inmediata', desc: 'Recibe tu voucher por email en segundos. Sin esperas ni incertidumbre.', bg: 'bg-accent/40', border: 'border-accent' },
          { icon: '🤝', title: 'Atención 24/7', desc: 'Nuestro equipo está disponible las 24 horas por WhatsApp, email o teléfono.', bg: 'bg-secondary/15', border: 'border-secondary' },
          { icon: '✅', title: 'Cancelación Flexible', desc: 'Cancela hasta 24-48h antes sin penalización. Planes que se adaptan a ti.', bg: 'bg-emerald-100', border: 'border-emerald-300' },
        ].map(({ icon, title, desc, bg, border }, i) => (
          <div class={`reveal-up delay-${(i + 1) * 100} bg-base-100 border-2 border-neutral shadow-pop rounded-2xl p-6 text-center group hover:shadow-pop-lg transition-all duration-200`}>
            <div class={`w-16 h-16 rounded-xl ${bg} border-2 ${border} flex items-center justify-center text-3xl mx-auto mb-4`}>
              {icon}
            </div>
            <h3 class="font-black text-neutral text-lg mb-2">{title}</h3>
            <p class="text-neutral/55 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

