---
import Layout from '../layouts/Layout.astro';
import { api } from '../lib/api';

const featuredHotels   = await api.getFeaturedHotels().catch(() => []);
const featuredTours    = await api.getFeaturedTours().catch(() => []);
const featuredTransfers = await api.getFeaturedTransfers().catch(() => []);
const banners          = await api.getBanners('home').catch(() => []);

const heroSubtitle = banners[0]?.subtitle || 'Tours, hoteles y traslados en el Caribe Mexicano. Más de 5,000 viajeros felices.';

const homeSchema = {
  '@context': 'https://schema.org',
  '@type': 'TouristDestination',
  name: 'Riviera Maya & Cancún',
  description: 'Destino turístico de clase mundial en el Caribe Mexicano con playas, ruinas mayas y vida marina excepcional',
  touristType: ['Families', 'Couples', 'Solo Travelers'],
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 20.6534,
    longitude: -87.0696,
  },
};
---

<Layout
  title="Booking Caribe - Tours, Hoteles y Traslados en Riviera Maya & Cancún"
  description="Reserva tours, hoteles y traslados en Cancún, Playa del Carmen, Tulum y Riviera Maya. Mejores precios garantizados. ¡Más de 5,000 viajeros satisfechos!"
  keywords="tours cancun, hoteles riviera maya, traslado aeropuerto cancun, booking caribe, tours playa del carmen, excursiones tulum, tours cozumel, tours chichen itza"
  schema={homeSchema}
>

  <!-- ══════════════════════════════════════════
       HERO SECTION — Playful Geometric
  ══════════════════════════════════════════ -->
  <section class="hero-geometric min-h-[92vh] flex items-center relative overflow-hidden" aria-label="Inicio">

    <!-- Dot grid background -->
    <div class="absolute inset-0 pattern-dots-light opacity-60" aria-hidden="true"></div>

    <!-- Decorative shapes -->
    <div class="absolute -top-10 right-0 w-72 h-72 rounded-full bg-accent border-2 border-neutral opacity-70 translate-x-1/4 -translate-y-1/4" aria-hidden="true"></div>
    <div class="absolute top-32 right-24 w-16 h-16 bg-secondary border-2 border-neutral rotate-12 hidden md:block" aria-hidden="true"></div>
    <div class="absolute top-1/2 right-8 w-10 h-10 rounded-full bg-primary border-2 border-neutral hidden lg:block" aria-hidden="true"></div>
    <div class="absolute bottom-16 -left-10 w-48 h-48 rounded-full bg-primary/20 border-2 border-neutral" aria-hidden="true"></div>
    <div class="absolute bottom-32 left-40 w-8 h-8 bg-accent border-2 border-neutral rotate-45 hidden md:block" aria-hidden="true"></div>
    <!-- Confetti stars -->
    <div class="absolute top-40 left-1/4 text-2xl hidden lg:block select-none" aria-hidden="true">✦</div>
    <div class="absolute top-56 left-1/3 text-lg hidden lg:block select-none text-secondary" aria-hidden="true">★</div>
    <div class="absolute top-28 right-1/3 text-xl hidden lg:block select-none text-primary" aria-hidden="true">◆</div>

    <!-- Hero Content -->
    <div class="container mx-auto px-4 py-24 relative z-10">
      <div class="max-w-3xl">

        <!-- Badge chip -->
        <div class="fade-in-hero-1 inline-flex items-center gap-2 bg-accent border-2 border-neutral shadow-pop-sm rounded-full px-4 py-1.5 text-neutral text-sm font-bold mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-neutral"></span>
          Cancún · Riviera Maya · Caribe Mexicano
        </div>

        <!-- Main Headline -->
        <h1 class="fade-in-hero-2 text-6xl sm:text-7xl md:text-8xl font-black text-neutral leading-none tracking-tighter mb-6">
          Tu paraíso,<br>
          <span class="price-gradient">reservado.</span>
        </h1>

        <!-- Subtitle -->
        <p class="fade-in-hero-3 text-xl text-neutral/60 max-w-xl leading-relaxed mb-10">
          {heroSubtitle}
        </p>

        <!-- CTA Buttons -->
        <div class="fade-in-hero-4 flex flex-wrap gap-3 mb-10">
          <a href="/tours" class="inline-flex items-center gap-2 h-12 px-7 text-base font-bold rounded-full bg-violet-500 text-white border-2 border-neutral shadow-pop hover:translate-x-px hover:translate-y-px hover:shadow-pop-sm active:translate-x-[3px] active:translate-y-[3px] active:shadow-none transition-all">
            🌴 Explorar Tours
          </a>
          <a href="/hotels" class="inline-flex items-center gap-2 h-12 px-7 text-base font-bold rounded-full bg-amber-400 text-neutral border-2 border-neutral shadow-pop hover:translate-x-px hover:translate-y-px hover:shadow-pop-sm active:translate-x-[3px] active:translate-y-[3px] active:shadow-none transition-all">
            🏨 Ver Hoteles
          </a>
          <a href="/transfers" class="inline-flex items-center gap-2 h-12 px-7 text-base font-bold rounded-full bg-sky-500 text-white border-2 border-neutral shadow-pop hover:translate-x-px hover:translate-y-px hover:shadow-pop-sm active:translate-x-[3px] active:translate-y-[3px] active:shadow-none transition-all">
            🚐 Traslados
          </a>
        </div>

        <!-- Trust chips -->
        <div class="fade-in-hero-4 flex flex-wrap gap-2">
          {[
            { icon: '⭐', label: '4.9 · 5,000+ viajeros' },
            { icon: '✓', label: 'Cancelación gratuita' },
            { icon: '🕐', label: 'Atención 24/7' },
            { icon: '💰', label: 'Mejor precio' },
          ].map(({ icon, label }) => (
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-neutral bg-white border-2 border-neutral shadow-pop-sm rounded-full px-3 py-1.5">
              {icon} {label}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       STATS STRIP
  ══════════════════════════════════════════ -->
  <section class="relative bg-amber-400 border-y-2 border-neutral py-10 overflow-hidden" aria-label="Estadísticas">
    <div class="absolute inset-0 pattern-dots opacity-20" aria-hidden="true"></div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
        {[
          { number: '200+', label: 'Tours disponibles', icon: '🌴' },
          { number: '150+', label: 'Hoteles seleccionados', icon: '🏨' },
          { number: '50+', label: 'Rutas de traslado', icon: '🚐' },
          { number: '5,000+', label: 'Viajeros satisfechos', icon: '⭐' },
        ].map(({ number, label, icon }, i) => (
          <div class={`reveal-up delay-${(i + 1) * 100} text-center`}>
            <div class="text-2xl mb-1" aria-hidden="true">{icon}</div>
            <div class="text-3xl font-black text-neutral stat-number">{number}</div>
            <div class="text-sm text-neutral/65 mt-0.5">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       CATEGORY CARDS
  ══════════════════════════════════════════ -->
  <section class="bg-base-100 py-20" aria-label="Categorías de servicios">
    <div class="container mx-auto px-4">
      <div class="text-center mb-14">
        <div class="reveal-up inline-flex items-center gap-2 bg-primary border-2 border-neutral shadow-pop-sm rounded-full px-4 py-1 text-white text-xs font-bold mb-4 uppercase tracking-widest">
          Nuestros Servicios
        </div>
        <h2 class="reveal-up delay-100 text-4xl md:text-5xl font-black text-neutral">¿Qué estás buscando?</h2>
        <p class="reveal-up delay-200 text-neutral/55 mt-4 max-w-xl mx-auto text-lg">
          Desde traslados al aeropuerto hasta tours exclusivos — todo lo que necesitas para vivir el Caribe.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Hotels — Emerald accent -->
        <a href="/hotels" class="cat-card reveal-scale delay-100 h-72 block rounded-2xl overflow-hidden" aria-label="Ver hoteles">
          <div class="absolute inset-0 bg-emerald-500"></div>
          <div class="absolute inset-0 pattern-dots opacity-10" aria-hidden="true"></div>
          <div class="cat-overlay"></div>
          <div class="cat-content">
            <div class="text-4xl mb-2" aria-hidden="true">🏨</div>
            <h3 class="text-2xl font-black text-white">Hoteles</h3>
            <p class="text-white/80 text-sm mt-1">Los mejores alojamientos de la Riviera Maya</p>
            <div class="mt-3 inline-flex items-center gap-1.5 text-emerald-100 text-sm font-bold">
              Explorar hoteles
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        </a>

        <!-- Tours (larger middle card) — Violet accent -->
        <a href="/tours" class="cat-card reveal-scale delay-200 h-72 md:h-80 block rounded-2xl overflow-hidden md:-mt-4" aria-label="Ver tours">
          <div class="absolute inset-0 bg-violet-500"></div>
          <div class="absolute inset-0 pattern-dots opacity-10" aria-hidden="true"></div>
          <div class="cat-overlay"></div>
          <div class="cat-content">
            <div class="text-4xl mb-2" aria-hidden="true">🌴</div>
            <h3 class="text-2xl font-black text-white">Tours & Actividades</h3>
            <p class="text-white/80 text-sm mt-1">Experiencias únicas en el Caribe Mexicano</p>
            <div class="mt-3 inline-flex items-center gap-1.5 text-violet-100 text-sm font-bold">
              Ver tours
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        </a>

        <!-- Transfers — Pink accent -->
        <a href="/transfers" class="cat-card reveal-scale delay-300 h-72 block rounded-2xl overflow-hidden" aria-label="Ver traslados">
          <div class="absolute inset-0 bg-sky-500"></div>
          <div class="absolute inset-0 pattern-dots opacity-10" aria-hidden="true"></div>
          <div class="cat-overlay"></div>
          <div class="cat-content">
            <div class="text-4xl mb-2" aria-hidden="true">🚐</div>
            <h3 class="text-2xl font-black text-white">Traslados</h3>
            <p class="text-white/80 text-sm mt-1">Privados y compartidos desde el aeropuerto</p>
            <div class="mt-3 inline-flex items-center gap-1.5 text-sky-100 text-sm font-bold">
              Ver traslados
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       FEATURED TOURS
  ══════════════════════════════════════════ -->
  <section class="bg-slate-50 py-20" aria-label="Tours destacados">
    <div class="container mx-auto px-4">
      <div class="flex flex-col md:flex-row items-start md:items-end justify-between mb-12 gap-4">
        <div>
          <div class="reveal-up inline-flex items-center gap-2 bg-secondary border-2 border-neutral shadow-pop-sm rounded-full px-4 py-1 text-white text-xs font-bold mb-3 uppercase tracking-widest">
            Tours Destacados
          </div>
          <h2 class="reveal-up delay-100 text-4xl md:text-5xl font-black text-neutral">Experiencias que<br>cambian vidas</h2>
          <p class="reveal-up delay-200 text-neutral/55 mt-3 max-w-lg text-lg">
            Chichén Itzá, cenotes, Cozumel, Tulum… cada tour es una historia que contar.
          </p>
        </div>
        <a href="/tours" class="reveal-up delay-300 inline-flex items-center h-10 px-6 text-sm font-bold rounded-full bg-violet-500 text-white border-2 border-neutral shadow-pop-sm hover:translate-x-px hover:translate-y-px hover:shadow-none transition-all shrink-0">
          Ver todos los tours →
        </a>
      </div>

      {featuredTours.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredTours.slice(0, 6).map((tour, i) => (
            <article class={`bg-white border-2 border-neutral shadow-pop card-sticker reveal-up delay-${Math.min((i % 3 + 1) * 100, 400)} overflow-hidden rounded-2xl`}>
              <figure class="h-52 relative overflow-hidden">
                <div class="absolute inset-0 bg-violet-100"></div>
                <div class="absolute inset-0 pattern-dots-light opacity-50" aria-hidden="true"></div>
                <div class="absolute inset-0 flex items-center justify-center text-6xl opacity-30" aria-hidden="true">🌴</div>
                {tour.featured && (
                  <div class="absolute top-3 right-3 bg-secondary text-white text-xs font-black px-3 py-1 rounded-full border-2 border-neutral shadow-pop-sm">✦ Destacado</div>
                )}
                <div class="absolute top-3 left-3">
                  <span class="bg-neutral text-white text-xs font-black px-2.5 py-1 rounded-full">
                    {tour.difficulty_level === 'easy' ? 'Fácil' : tour.difficulty_level === 'moderate' ? 'Moderado' : 'Difícil'}
                  </span>
                </div>
              </figure>

              <div class="p-5">
                <h3 class="font-black text-lg leading-tight line-clamp-2 text-neutral">{tour.name}</h3>
                <p class="text-sm text-neutral/55 line-clamp-2 mt-1">{tour.description}</p>

                <div class="flex flex-wrap gap-3 mt-3 text-xs text-neutral/50 font-medium">
                  <span class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    {tour.duration}
                  </span>
                  <span class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    Hasta {tour.max_people} personas
                  </span>
                </div>

                <div class="flex items-center justify-between mt-4 pt-4 border-t-2 border-neutral/10">
                  <div>
                    <p class="text-xs text-neutral/40 font-medium">Desde</p>
                    <p class="text-2xl font-black price-gradient">
                      ${tour.price_adult.toLocaleString('es-MX')}
                      <span class="text-xs font-normal text-neutral/40 ml-0.5">MXN</span>
                    </p>
                  </div>
                  <a href={`/tours/${tour.slug}`} class="inline-flex items-center h-9 px-5 text-sm font-bold rounded-full bg-violet-500 text-white border-2 border-neutral shadow-pop-sm hover:translate-x-px hover:translate-y-px hover:shadow-none transition-all">
                    Reservar
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 text-neutral/40">
          <p class="text-6xl mb-4">🌴</p>
          <p class="text-xl font-bold">Tours próximamente disponibles</p>
        </div>
      )}
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       FEATURED HOTELS
  ══════════════════════════════════════════ -->
  <section class="bg-base-100 py-20" aria-label="Hoteles recomendados">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <div class="reveal-up inline-flex items-center gap-2 bg-emerald-500 border-2 border-neutral shadow-pop-sm rounded-full px-4 py-1 text-white text-xs font-bold mb-3 uppercase tracking-widest">
          Hoteles Recomendados
        </div>
        <h2 class="reveal-up delay-100 text-4xl md:text-5xl font-black text-neutral">Alojamientos de ensueño</h2>
        <p class="reveal-up delay-200 text-neutral/55 mt-3 max-w-lg mx-auto text-lg">
          Desde boutiques íntimos hasta resorts all-inclusive con vista al mar Caribe.
        </p>
      </div>

      {featuredHotels.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {featuredHotels.slice(0, 4).map((hotel, i) => (
            <article class={`flex flex-col lg:flex-row bg-white border-2 border-neutral shadow-pop card-sticker reveal-${i % 2 === 0 ? 'left' : 'right'} delay-${(i % 2 + 1) * 100} overflow-hidden rounded-2xl`}>
              <figure class="lg:w-44 h-44 lg:h-auto relative shrink-0">
                <div class="absolute inset-0 bg-emerald-100"></div>
                <div class="absolute inset-0 pattern-dots-light opacity-50" aria-hidden="true"></div>
                <div class="absolute inset-0 flex items-center justify-center text-5xl opacity-30" aria-hidden="true">🏨</div>
              </figure>
              <div class="p-5 flex flex-col flex-1">
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-black text-lg leading-tight text-neutral">{hotel.name}</h3>
                  <div class="flex shrink-0">
                    {[...Array(hotel.stars)].map(() => (
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-amber-400 fill-amber-400" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    ))}
                  </div>
                </div>
                <p class="text-sm text-neutral/55 line-clamp-2 mt-1">{hotel.description}</p>
                <div class="flex items-center gap-1.5 text-xs text-neutral/45 mt-2 font-medium">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  </svg>
                  {hotel.city}{hotel.state ? `, ${hotel.state}` : ''}
                </div>
                <div class="flex items-center justify-between mt-4 pt-3 border-t-2 border-neutral/10">
                  <div>
                    <p class="text-xs text-neutral/40 font-medium">Por noche desde</p>
                    <p class="text-2xl font-black price-gradient">
                      ${hotel.price_per_night.toLocaleString('es-MX')}
                    </p>
                  </div>
                  <a href={`/hotels/${hotel.slug}`} class="inline-flex items-center h-9 px-5 text-sm font-bold rounded-full bg-emerald-500 text-white border-2 border-neutral shadow-pop-sm hover:translate-x-px hover:translate-y-px hover:shadow-none transition-all">
                    Reservar
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 text-neutral/40">
          <p class="text-6xl mb-4">🏨</p>
          <p class="text-xl font-bold">Hoteles próximamente disponibles</p>
        </div>
      )}

      <div class="text-center mt-10">
        <a href="/hotels" class="inline-flex items-center h-12 px-7 text-base font-bold rounded-full bg-transparent text-neutral border-2 border-neutral shadow-pop hover:translate-x-px hover:translate-y-px hover:shadow-pop-sm active:translate-x-[3px] active:translate-y-[3px] active:shadow-none transition-all">
          Ver todos los hoteles →
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       FEATURED TRANSFERS
  ══════════════════════════════════════════ -->
  <section class="bg-slate-50 py-20" aria-label="Traslados disponibles">
    <div class="container mx-auto px-4">
      <div class="flex flex-col md:flex-row items-start md:items-end justify-between mb-12 gap-4">
        <div>
          <div class="reveal-up inline-flex items-center gap-2 bg-sky-500 border-2 border-neutral shadow-pop-sm rounded-full px-4 py-1 text-white text-xs font-bold mb-3 uppercase tracking-widest">
            Traslados
          </div>
          <h2 class="reveal-up delay-100 text-4xl md:text-5xl font-black text-neutral">Llega sin estrés</h2>
          <p class="reveal-up delay-200 text-neutral/55 mt-3 max-w-lg text-lg">
            Del aeropuerto de Cancún a tu hotel — privado o compartido, puntual y cómodo.
          </p>
        </div>
        <a href="/transfers" class="reveal-up delay-300 inline-flex items-center h-10 px-6 text-sm font-bold rounded-full bg-sky-500 text-white border-2 border-neutral shadow-pop-sm hover:translate-x-px hover:translate-y-px hover:shadow-none transition-all shrink-0">
          Ver todos los traslados →
        </a>
      </div>

      {featuredTransfers.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredTransfers.slice(0, 3).map((transfer, i) => (
            <article class={`bg-white border-2 border-neutral shadow-pop card-sticker reveal-up delay-${(i + 1) * 100} rounded-2xl`}>
              <div class="p-6">
                <div class="flex items-start justify-between gap-2 mb-4">
                  <h3 class="font-black text-lg leading-tight text-neutral">{transfer.name}</h3>
                  <span class={`text-xs font-bold px-2.5 py-1 rounded-full border-2 border-neutral shadow-pop-sm shrink-0 ${transfer.is_private ? 'bg-sky-500 text-white' : 'bg-accent text-neutral'}`}>
                    {transfer.is_private ? 'Privado' : 'Compartido'}
                  </span>
                </div>

                <!-- Route visualization -->
                <div class="bg-slate-50 border-2 border-neutral rounded-xl p-4 mb-4">
                  <div class="flex items-center gap-2 text-sm font-semibold">
                    <div class="w-2.5 h-2.5 rounded-full bg-emerald-500 border border-neutral shrink-0"></div>
                    <span class="truncate text-neutral">{transfer.from_location}</span>
                  </div>
                  <div class="my-1.5 w-0.5 h-4 bg-neutral/30 ml-[5px]"></div>
                  <div class="flex items-center gap-2 text-sm font-semibold">
                    <div class="w-2.5 h-2.5 rounded-full bg-red-400 border border-neutral shrink-0"></div>
                    <span class="truncate text-neutral">{transfer.to_location}</span>
                  </div>
                </div>

                <div class="grid grid-cols-2 gap-3 text-sm text-neutral/55 font-medium">
                  <span class="flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    {transfer.max_passengers} pasajeros
                  </span>
                  <span class="flex items-center gap-1.5 capitalize">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                    </svg>
                    {transfer.vehicle_type}
                  </span>
                </div>

                <div class="flex items-center justify-between mt-5 pt-4 border-t-2 border-neutral/10">
                  <div>
                    <p class="text-xs text-neutral/40 font-medium">
                      {transfer.type === 'one-way' ? 'Solo ida' : 'Ida y vuelta'}
                    </p>
                    <p class="text-2xl font-black price-gradient">
                      ${transfer.price.toLocaleString('es-MX')}
                    </p>
                  </div>
                  <a href={`/transfers/${transfer.slug}`} class="inline-flex items-center h-9 px-5 text-sm font-bold rounded-full bg-sky-500 text-white border-2 border-neutral shadow-pop-sm hover:translate-x-px hover:translate-y-px hover:shadow-none transition-all">
                    Reservar
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-16 text-neutral/40">
          <p class="text-6xl mb-4">🚐</p>
          <p class="text-xl font-bold">Traslados próximamente disponibles</p>
        </div>
      )}
    </div>
  </section>

  <!-- ══════════════════════════════════════════
