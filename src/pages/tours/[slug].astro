---
import Layout from '../../layouts/Layout.astro';
import BookingForm from '../../components/BookingForm';
import { api } from '../../lib/api';

const { slug } = Astro.params;

let tour;
try {
  tour = await api.getTour(slug!);
} catch {
  return Astro.redirect('/tours');
}

const included = (() => {
  try { return tour.included ? JSON.parse(tour.included as unknown as string) : []; }
  catch { return Array.isArray(tour.included) ? tour.included : []; }
})();

const notIncluded = (() => {
  try { return tour.not_included ? JSON.parse(tour.not_included as unknown as string) : []; }
  catch { return Array.isArray(tour.not_included) ? tour.not_included : []; }
})();

const difficultyLabel = tour.difficulty_level === 'easy' ? 'Fácil' : tour.difficulty_level === 'moderate' ? 'Moderado' : 'Difícil';
const difficultyBg = tour.difficulty_level === 'easy' ? 'bg-green-100 text-green-700 border-green-300' : tour.difficulty_level === 'moderate' ? 'bg-amber-100 text-amber-700 border-amber-300' : 'bg-red-100 text-red-700 border-red-300';

const tourSchema = {
  '@context': 'https://schema.org',
  '@type': 'TouristAttraction',
  name: tour.name,
  description: tour.description,
  touristType: ['Families', 'Couples', 'Solo Travelers'],
  geo: tour.latitude && tour.longitude ? {
    '@type': 'GeoCoordinates',
    latitude: tour.latitude,
    longitude: tour.longitude,
  } : undefined,
  address: {
    '@type': 'PostalAddress',
    addressLocality: tour.destination,
    addressRegion: 'Quintana Roo',
    addressCountry: 'MX',
  },
  offers: {
    '@type': 'Offer',
    price: tour.price_adult,
    priceCurrency: 'MXN',
    availability: 'https://schema.org/InStock',
    url: `https://bookingcaribe.com/tours/${tour.slug}`,
  },
};
---

<Layout
  title={`${tour.name} - Tour en ${tour.destination}`}
  description={`Reserva el tour ${tour.name} en ${tour.destination}. Duración: ${tour.duration}. Desde $${tour.price_adult.toLocaleString('es-MX')} MXN por adulto. ${tour.description?.slice(0, 100) || ''}`}
  keywords={`${tour.name}, tour ${tour.destination}, excursión ${tour.destination}, ${tour.name} precio, tour ${tour.destination} reservar`}
  schema={tourSchema}
>
  <!-- Breadcrumb bar -->
  <div class="bg-base-100 border-b-2 border-neutral/10 pt-20">
    <div class="container mx-auto px-4 py-3">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm font-semibold text-neutral/45">
        <a href="/" class="hover:text-violet-600 transition-colors">Inicio</a>
        <span>›</span>
        <a href="/tours" class="hover:text-violet-600 transition-colors">Tours</a>
        <span>›</span>
        <span class="text-neutral truncate max-w-[200px]">{tour.name}</span>
      </nav>
    </div>
  </div>

  <div class="bg-base-100 min-h-screen">
    <div class="container mx-auto px-4 py-10">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- ── Main Content ── -->
        <div class="lg:col-span-2 space-y-8">

          <!-- Header -->
          <div class="reveal-up">
            <div class="flex flex-wrap gap-2 mb-3">
              <div class="inline-flex items-center gap-2 bg-violet-500 border-2 border-neutral shadow-pop-sm rounded-full px-3 py-0.5 text-white text-xs font-black uppercase tracking-widest">
                🌴 Tour
              </div>
              {tour.featured && (
                <span class="inline-flex items-center bg-secondary text-white text-xs font-black px-3 py-0.5 rounded-full border-2 border-neutral shadow-pop-sm">
                  ✦ Destacado
                </span>
              )}
              <span class={`inline-flex items-center text-xs font-black px-3 py-0.5 rounded-full border-2 ${difficultyBg}`}>
                {difficultyLabel}
              </span>
            </div>

            <h1 class="text-3xl md:text-5xl font-black text-neutral leading-none tracking-tight mb-4">{tour.name}</h1>

            <!-- Quick info pills -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
              {[
                { icon: '⏱️', label: 'Duración', value: tour.duration },
                { icon: '👥', label: 'Grupo máx.', value: `${tour.max_people} pers.` },
                { icon: '📍', label: 'Destino', value: tour.destination },
                { icon: '🗺️', label: 'Encuentro', value: tour.meeting_point || 'Por confirmar' },
              ].map(({ icon, label, value }) => (
                <div class="bg-white border-2 border-neutral shadow-pop-sm rounded-xl p-3 text-center">
                  <span class="text-lg" aria-hidden="true">{icon}</span>
                  <p class="text-xs text-neutral/45 font-black uppercase tracking-wider mt-1">{label}</p>
                  <p class="text-sm font-black text-neutral mt-0.5 line-clamp-1">{value}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Hero image -->
          <div class="reveal-up delay-100 h-72 md:h-96 rounded-2xl overflow-hidden relative border-2 border-neutral shadow-pop">
            <div class="absolute inset-0 bg-violet-100"></div>
            <div class="absolute inset-0 pattern-dots-light opacity-50" aria-hidden="true"></div>
            <div class="absolute top-6 right-6 w-24 h-24 rounded-full bg-violet-200/60 border-2 border-violet-300/40" aria-hidden="true"></div>
            <div class="absolute bottom-8 left-8 w-28 h-28 rounded-full bg-violet-200/40 border-2 border-violet-300/30" aria-hidden="true"></div>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <div class="text-8xl opacity-40">🌴</div>
              <p class="mt-3 text-sm font-bold text-violet-400">Fotos del tour próximamente</p>
            </div>
            <!-- Price tag overlay -->
            <div class="absolute bottom-4 right-4 bg-white border-2 border-neutral shadow-pop-sm rounded-xl px-4 py-2">
              <p class="text-xs text-neutral/50 font-medium">Adulto desde</p>
              <p class="text-xl font-black price-gradient">${tour.price_adult.toLocaleString('es-MX')} <span class="text-xs font-normal text-neutral/40">MXN</span></p>
            </div>
          </div>

          <!-- Description -->
          <div class="reveal-up delay-100 bg-white border-2 border-neutral shadow-pop rounded-2xl p-6">
            <h2 class="text-2xl font-black text-neutral mb-4 flex items-center gap-2">
              <span class="w-8 h-8 bg-violet-500 rounded-lg border-2 border-neutral shadow-pop-sm flex items-center justify-center text-white text-sm">📋</span>
              Sobre este tour
            </h2>
            <p class="text-neutral/65 leading-relaxed">{tour.description}</p>
            {tour.highlights && (
              <div class="mt-5 p-4 bg-violet-50 border-2 border-violet-200 rounded-xl">
                <h3 class="font-black text-violet-700 text-sm mb-2">✨ Highlights</h3>
                <p class="text-sm text-neutral/65 leading-relaxed">{tour.highlights}</p>
              </div>
            )}
          </div>

          <!-- Included / Not Included -->
          <div class="reveal-up delay-200 grid md:grid-cols-2 gap-6">
            <!-- Included -->
            <div class="bg-white border-2 border-neutral shadow-pop rounded-2xl p-5">
              <h3 class="text-lg font-black text-neutral mb-4 flex items-center gap-2">
                <span class="w-7 h-7 bg-green-100 border-2 border-green-400 rounded-lg flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                Incluye
              </h3>
              {included.length > 0 ? (
                <ul class="space-y-2">
                  {included.map((item: string) => (
                    <li class="flex items-start gap-2.5 text-sm">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="text-neutral/70 font-medium">{item}</span>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="text-sm text-neutral/45 font-medium">Consultar con el operador</p>
              )}
            </div>

            <!-- Not Included -->
            <div class="bg-white border-2 border-neutral shadow-pop rounded-2xl p-5">
              <h3 class="text-lg font-black text-neutral mb-4 flex items-center gap-2">
                <span class="w-7 h-7 bg-red-100 border-2 border-red-300 rounded-lg flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </span>
                No incluye
              </h3>
              {notIncluded.length > 0 ? (
                <ul class="space-y-2">
                  {notIncluded.map((item: string) => (
                    <li class="flex items-start gap-2.5 text-sm">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-red-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
                      </svg>
                      <span class="text-neutral/70 font-medium">{item}</span>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="text-sm text-neutral/45 font-medium">No especificado</p>
              )}
            </div>
          </div>

          <!-- Important info -->
          <div class="reveal-up delay-300 bg-white border-2 border-neutral shadow-pop rounded-2xl p-5">
            <div class="flex items-start gap-3">
              <div class="w-9 h-9 bg-violet-50 border-2 border-violet-200 rounded-xl flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="font-black text-neutral mb-2">Información importante</p>
                <ul class="text-sm text-neutral/60 space-y-1.5">
                  <li class="flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-violet-500 shrink-0"></span>
                    Llega 15 minutos antes de la hora de salida
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-violet-500 shrink-0"></span>
                    Usa ropa cómoda y protector solar
                  </li>
                  <li class="flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-violet-500 shrink-0"></span>
                    Cancelación gratuita hasta 24h antes
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- ── Sidebar ── -->
        <div class="lg:col-span-1">
          <div class="sticky top-24 space-y-4">

            <!-- Booking card -->
            <div class="bg-white border-2 border-neutral shadow-pop rounded-2xl p-6 reveal-right">
              <div class="mb-5">
                <p class="text-xs text-neutral/45 uppercase tracking-widest font-black mb-1">Precio por adulto desde</p>
                <p class="text-4xl font-black price-gradient">
                  ${tour.price_adult.toLocaleString('es-MX')}
                  <span class="text-sm font-normal text-neutral/45 ml-1">MXN</span>
                </p>
                {tour.price_child && (
                  <p class="text-xs text-neutral/45 mt-1 font-medium">
                    Niños: ${tour.price_child.toLocaleString('es-MX')} MXN
                  </p>
                )}
              </div>

              <div class="border-t-2 border-neutral/10 my-4"></div>

              <BookingForm
                client:load
                itemType="tour"
                itemId={tour.id}
                itemName={tour.name}
                itemPrice={tour.price_adult}
                itemSlug={tour.slug}
                childPrice={tour.price_child || undefined}
              />

              <div class="border-t-2 border-neutral/10 my-4"></div>

              <a
                href={`https://wa.me/529981234567?text=${encodeURIComponent(`Hola, me interesa el tour: ${tour.name}`)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="w-full inline-flex items-center justify-center gap-2 h-10 bg-green-500 text-white font-black text-sm rounded-full border-2 border-neutral shadow-pop-sm
                       hover:-translate-x-[2px] hover:-translate-y-[2px] hover:shadow-pop transition-all duration-150"
              >
                <svg class="h-4 w-4 fill-current shrink-0" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zm-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884z"/>
                </svg>
                Consultar por WhatsApp
              </a>
            </div>

            <!-- Trust card -->
            <div class="bg-white border-2 border-neutral/15 rounded-2xl p-4 reveal-right delay-100">
              <div class="flex items-start gap-3">
                <div class="w-9 h-9 bg-green-100 border-2 border-green-300 rounded-xl flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                </div>
                <div>
                  <p class="font-black text-sm text-neutral">Cancelación Gratuita</p>
                  <p class="text-xs text-neutral/55 mt-0.5 leading-relaxed">Cancela hasta 24 horas antes sin ningún cargo.</p>
                </div>
              </div>
            </div>

            <!-- More trust items -->
            <div class="bg-white border-2 border-neutral/15 rounded-2xl p-4 space-y-3 reveal-right delay-200">
              {[
                { icon: '👨‍🏫', title: 'Guías certificados', desc: 'Expertos locales bilingües' },
                { icon: '🎫', title: 'Confirmación inmediata', desc: 'Recibe tu voucher al instante' },
                { icon: '🏆', title: 'Mejor precio', desc: 'Garantía de precio más bajo' },
              ].map(({ icon, title, desc }) => (
                <div class="flex items-center gap-3 text-sm">
                  <span class="text-xl w-7 text-center">{icon}</span>
                  <div>
                    <p class="font-black text-neutral leading-none">{title}</p>
                    <p class="text-xs text-neutral/45 mt-0.5">{desc}</p>
                  </div>
                </div>
              ))}
            </div>

          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Bottom CTA -->
  <section class="bg-slate-50 border-t-2 border-neutral/10 py-14">
    <div class="container mx-auto px-4 text-center">
      <p class="text-xs font-black uppercase tracking-widest text-neutral/40 mb-2">¿Buscas más aventuras?</p>
      <h2 class="text-3xl font-black text-neutral mb-2">Más tours en {tour.destination}</h2>
      <p class="text-neutral/55 mb-6">Descubre otras experiencias únicas en el Caribe Mexicano</p>
      <a
        href="/tours"
        class="inline-flex items-center gap-2 bg-violet-500 text-white font-black px-8 py-3 rounded-full border-2 border-neutral shadow-pop hover:-translate-x-px hover:-translate-y-px hover:shadow-pop-lg transition-all"
      >
        Ver todos los tours →
      </a>
    </div>
  </section>
</Layout>
